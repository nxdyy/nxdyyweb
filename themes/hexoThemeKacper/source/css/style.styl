@import "nib"
@import "_variables"
@import "_util/mixin"
@import "_util/grid"

global-reset()

@font-face
  font-family: 'FontAwesome'
  src: url('fonts/fontawesome-webfont.eot?v=4.0.3')
  src: url('fonts/fontawesome-webfont.eot?#iefix&v=4.0.3') format('embedded-opentype'),
       url('fonts/fontawesome-webfont.woff2?v=4.0.3') format('woff2'),
       url('fonts/fontawesome-webfont.woff?v=4.0.3') format('woff'),
       url('fonts/fontawesome-webfont.ttf?v=4.0.3') format('truetype'),
       url('fonts/fontawesome-webfont.svg?v=4.0.3#fontawesomeregular') format('svg')
  font-weight: normal
  font-style: normal

html, body, #container
  height: 100%

body
  background: color-background
  font: font-size font-sans
  -webkit-text-size-adjust: 100%
  -webkit-font-smoothing: antialiased
  -moz-osx-font-smoothing: grayscale

a
  text-decoration: none
  transition: all transition-fast

.outer
  clearfix()
  margin: 0 auto
  padding: 0 gutter-width
  max-width: 1400px
  @media mq-mobile
    padding: 0 16px

.inner
  column(columns)

.left, .alignleft
  float: left

.right, .alignright
  float: right

.clear
  clear: both

#container
  position: relative
  background: linear-gradient(180deg, color-background 0%, #fff 100%)
  min-height: 100vh

.mobile-nav-on
  overflow: hidden

#wrap
  height: 100%
  width: 100%
  position: absolute
  top: 0
  left: 0
  transition: 0.2s ease-out
  z-index: 1
  background: transparent
  .mobile-nav-on &
    left: mobile-nav-width

if sidebar is left
  #main
    float: right

@import "_extend"
@import "_partial/header"
@import "_partial/article"
@import "_partial/comment"
@import "_partial/archive"
@import "_partial/footer"
@import "_partial/highlight"
@import "_partial/mobile"

if sidebar
  @import "_partial/sidebar"
