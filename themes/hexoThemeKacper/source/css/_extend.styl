$block-caption
  text-decoration: none
  text-transform: uppercase
  letter-spacing: 2px
  color: color-grey
  line-height: 1em
  font-weight: bold

$block
  border-radius: border-radius-md

$base-style
  h1
    font-size: 2em
  h2
    font-size: 1.5em
  h3
    font-size: 1.3em
  h4
    font-size: 1.2em
  h5
    font-size: 1em
  h6
    font-size: 1em
    color: color-grey
  hr
    border: 2px dashed color-border
    margin: 24px 0
  strong
    font-weight: 700
  em, cite
    font-style: italic
  sup, sub
    font-size: 0.75em
    line-height: 0
    position: relative
    vertical-align: baseline
  sup
    top: -0.5em
  sub
    bottom: -0.2em
  small
    font-size: 0.85em
  acronym, abbr
    border-bottom: 1px dotted color-link
  ul, ol, dl
    margin: 0 15px
    line-height: line-height
  ul, ol
    ul, ol
      margin-top: 0
      margin-bottom: 0
  ul
    list-style: disc
    li
      margin: 8px 0
      &::marker
        color: color-link
  ol
    list-style: decimal
    li
      margin: 8px 0
      &::marker
        color: color-link
  dt
    font-weight: bold
