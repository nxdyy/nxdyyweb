.archives-wrap
  margin: block-margin 0

.archives
  clearfix()

.archive-year-wrap
  margin-bottom: 1.5em
  padding-left: 16px
  position: relative
  &::before
    content: ''
    position: absolute
    left: 0
    top: 50%
    width: 4px
    height: 24px
    background: linear-gradient(180deg, color-primary, color-secondary)
    transform: translateY(-50%)
    border-radius: 2px

.archive-year
  @extend $block-caption
  color: color-primary

.archives
  column-gap: 20px
  @media mq-tablet
    column-count: 2
  @media mq-normal
    column-count: 3

.archive-article
  avoid-column-break()

.archive-article-inner
  @extend $block
  margin-bottom: 12px
  background: color-card-bg
  box-shadow: shadow-sm
  transition: all transition-normal
  border-radius: border-radius-md
  overflow: hidden
  a
    display: block
    padding: 12px 16px
    color: color-default
    transition: all transition-fast
    &:hover
      background: linear-gradient(135deg, rgba(108, 92, 231, 0.05), rgba(162, 155, 254, 0.05))
      color: color-primary
    &:active
      background: linear-gradient(135deg, color-primary, color-secondary)
      color: #fff
    time
      font-size: 13px
      color: color-grey
      display: block
      margin-bottom: 6px

.archive-article-title
  text-decoration: none
  font-weight: 600
  color: color-default
  transition: color transition-fast
  line-height: line-height
  &:hover
    color: color-link

.archive-article-footer
  margin-top: 1em

.archive-article-date
  color: color-grey
  text-decoration: none
  font-size: 0.85em
  line-height: 1em
  margin-bottom: 0.5em
  display: block

#page-nav
  clearfix()
  margin: block-margin auto
  background: color-card-bg
  box-shadow: shadow-md
  border-radius: border-radius-lg
  text-align: center
  color: color-grey
  overflow: hidden
  a, span
    padding: 12px 20px
    line-height: 1
    height: auto
  a
    color: color-grey
    text-decoration: none
    transition: all transition-fast
    &:hover
      background: linear-gradient(135deg, color-primary, color-secondary)
      color: #fff
  .prev
    float: left
    border-radius: border-radius-lg 0 0 border-radius-lg
    background: rgba(108, 92, 231, 0.1)
    &:hover
      background: linear-gradient(135deg, color-primary, color-secondary)
  .next
    float: right
    border-radius: 0 border-radius-lg border-radius-lg 0
    background: rgba(108, 92, 231, 0.1)
    &:hover
      background: linear-gradient(135deg, color-primary, color-secondary)
  .page-number
    display: inline-block
    @media mq-mobile
      display: none
  .current
    color: #fff
    font-weight: bold
    background: linear-gradient(135deg, color-primary, color-secondary)
  .space
    color: color-border

.category-list
  padding: 0 0 50px 0
  a
    color: color-default
    text-decoration: none
    transition: all transition-fast
    sup
      color: color-grey
      font-size: 10px
      vertical-align: super
      display: inline-block
      padding: 0 4px
      margin-left: 4px
      background: color-background
      border-radius: 10px
  .category-tag
    background: linear-gradient(135deg, rgba(108, 92, 231, 0.1), rgba(162, 155, 254, 0.1))
    border-radius: border-radius-sm
    display: inline-block
    padding: 0 8px
    color: color-primary
    font-weight: 500
  .tag-list
    padding: 0 0 30px 0
    a
      border: 1px solid color-border
      background: color-card-bg
      border-radius: border-radius-xl
      padding: 6px 12px
      margin: 6px 4px
      display: inline-block
      transition: all transition-fast
      &:hover
        background: linear-gradient(135deg, color-primary, color-secondary)
        color: #fff
        border-color: transparent
        transform: translateY(-2px)
        box-shadow: 0 4px 12px rgba(108, 92, 231, 0.3)
  .tag_name
    font-weight: bold
  h2
    margin: 20px 0 10px 0
    color: color-primary
  article
    border-left: 3px solid color-border
    padding: 10px 0 10px 12px
    margin: 8px 10px
    line-height: 24px
    transition: all transition-fast
    &:hover
      border-left-color: color-primary
    a
      padding: 4px 8px
      border-radius: border-radius-sm
      transition: all transition-fast
      &:hover
        background: linear-gradient(135deg, color-primary, color-secondary)
        color: #fff
