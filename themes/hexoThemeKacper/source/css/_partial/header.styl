.header
  height: banner-height
  position: relative
  background: transparent
  @media mq-mobile
    height: 300px

header.hdpage
  height: 80px
  background: rgba(255, 255, 255, 0.98)
  backdrop-filter: blur(20px)
  -webkit-backdrop-filter: blur(20px)
  box-shadow: shadow-sm
  transition: all transition-normal
  @media mq-mobile
    height: 60px

#header-outer
  height: 100%
  position: relative
  @media mq-mobile
    height: 85%

#header-inner
  position: relative
  overflow: visible
  z-index: 999

#banner
  position: absolute
  top: 0
  left: 0
  width: 100%
  height: 100%
  background-image: url(banner-url)
  background-position: center center
  background-repeat: no-repeat
  background-size: cover
  z-index: -1
  &::after
    content: ''
    position: absolute
    top: 0
    left: 0
    width: 100%
    height: 100%
    background: rgba(0, 0, 0, 0.3)

#header-title
  text-align: center
  height: auto
  position: absolute
  top: 50%
  left: 0
  transform: translateY(-50%)
  padding: 0 20px
  width: 100%

$logo-text
  text-decoration: none
  color: #fff
  font-weight: 300
  text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3)
  transition: all transition-normal

#logo
  @extend $logo-text
  font-size: logo-size
  font-weight: logo-weight
  text-shadow: logo-shadow
  font-style: normal
  line-height: logo-size
  letter-spacing: 3px
  display: inline-block
  transition: all transition-normal
  &:hover
    transform: scale(1.02)
    text-shadow: 0 4px 12px rgba(0, 0, 0, 0.4)
  @media mq-mobile
    font-size: 48px
    padding-bottom: 5px

#subtitle
  @extend $logo-text
  font-size: subtitle-size
  line-height: subtitle-line
  letter-spacing: 2px
  display: inline-block
  width: 90%
  max-width: 700px
  font-weight: 300
  opacity: 0.9
  @media mq-mobile
    font-size: 16px
    line-height: 22px

#subtitle-wrap
  margin-top: subtitle-size

#main-nav
  float: left
  margin-left: -15px
  padding: 6px 0
  &:first-child
    margin-left:0px
  @media mq-mobile
    padding: 6px 0

$nav-link
  float: left
  color: #fff
  opacity: 0.8
  text-decoration: none
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.2)
  transition: all transition-fast
  display: block
  padding: 20px 15px
  position: relative
  &::after
    content: ''
    position: absolute
    bottom: 10px
    left: 50%
    width: 0
    height: 2px
    background: color-primary
    transition: all transition-fast
    transform: translateX(-50%)
  &:hover
    opacity: 1
    &::after
      width: 80%

.nav-icon
  @extend $nav-link
  font-family: font-icon
  text-align: center
  font-size: font-size
  width: font-size
  height: font-size
  padding: 20px 15px
  position: relative
  cursor: pointer
  &::after
    display: none
  @media mq-mobile
    padding: 12px 15px

.main-nav-link
  @extend $nav-link
  letter-spacing: 1px
  font-weight: 500
  @media mq-mobile
    display: none

#main-nav-toggle
  display: none
  &:before
    content: "\f0c9"
  @media mq-mobile
    display: block

#sub-nav
  float: right
  margin-right: -15px
  padding: 6px 0
  @media mq-mobile
    padding: 6px 0

#nav-rss-link
  &:before
    content: "\f09e"

#nav-search-btn
  &:before
    content: "\f002"

#search-form-wrap
  position: absolute
  top: 15px
  width: 200px
  height: 36px
  right: -200px
  opacity: 0
  transition: all transition-normal
  &.on
    opacity: 1
    right: 0
  @media mq-mobile
    width: 100%
    right: -100%

.search-form
  position: absolute
  top: 0
  left: 0
  right: 0
  background: rgba(255, 255, 255, 0.95)
  backdrop-filter: blur(10px)
  padding: 8px 18px
  border-radius: border-radius-xl
  box-shadow: shadow-md

.search-form-input
  border: none
  background: none
  color: color-default
  width: 100%
  font: 14px font-sans
  outline: none
  &::-webkit-search-results-decoration
  &::-webkit-search-cancel-button
    -webkit-appearance: none

.search-form-submit
  position: absolute
  top: 50%
  right: 10px
  margin-top: -7px
  font: 14px font-icon
  border: none
  background: none
  color: color-primary
  cursor: pointer
  transition: color transition-fast
  &:hover, &:focus
    color: color-secondary

.page-buttons
  display: flex
  gap: 20px
  margin-top: 40px
  margin-bottom: 20px
  justify-content: center
  flex-wrap: wrap
  .page-btn
    position: relative
    display: inline-flex
    align-items: center
    padding: 14px 36px
    background: color-primary
    color: #fff
    text-decoration: none
    border-radius: border-radius-xl
    font-size: 0.95em
    font-weight: 600
    letter-spacing: 0.5px
    overflow: hidden
    transition: all transition-normal
    box-shadow: 0 4px 15px rgba(9, 132, 227, 0.3)
    cursor: pointer
    border: 2px solid transparent
    &::before
      content: ''
      position: absolute
      top: 50%
      left: 50%
      width: 0
      height: 0
      border-radius: 50%
      background: rgba(255, 255, 255, 0.2)
      transform: translate(-50%, -50%)
      transition: all transition-slow
    &:hover
      transform: translateY(-4px)
      box-shadow: 0 8px 25px rgba(9, 132, 227, 0.4)
      text-decoration: none
      background: color-secondary
      &::before
        width: 400px
        height: 400px
    &:active
      transform: translateY(-2px)
      box-shadow: 0 4px 12px rgba(9, 132, 227, 0.3)
