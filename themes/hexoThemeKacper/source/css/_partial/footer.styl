#footer
  background: #2d3436
  padding: 60px 0 40px
  color: rgba(255, 255, 255, 0.85)
  position: relative
  overflow: hidden
  a
    color: rgba(255, 255, 255, 0.9)
    text-decoration: none
    transition: all transition-fast
    position: relative
    &::after
      content: ''
      position: absolute
      bottom: -2px
      left: 0
      width: 0
      height: 2px
      background: color-primary
      transition: width transition-normal
    &:hover
      text-decoration: none
      color: #fff
      &::after
        width: 100%

#footer-info
  line-height: line-height
  font-size: 0.9em
  display: flex
  justify-content: space-between
  align-items: center
  flex-wrap: wrap
  gap: 20px
  .left
    text-align: left
    color: rgba(255, 255, 255, 0.7)
  .right
    display: flex
    gap: 12px
    flex-wrap: wrap
    a
      padding: 6px 14px
      background: rgba(255, 255, 255, 0.1)
      border-radius: border-radius-xl
      transition: all transition-normal
      color: rgba(255, 255, 255, 0.85)
      &:hover
        background: color-primary
        color: #fff
        transform: translateY(-2px)

#footer-custom
  margin-top: 30px
  padding-top: 20px
  border-top: 1px solid rgba(255, 255, 255, 0.1)
  text-align: center
  color: rgba(255, 255, 255, 0.75)
  font-size: 0.95em
  line-height: 1.8
  a
    color: color-primary
    font-weight: 500
    transition: color transition-fast
    &:hover
      color: color-secondary
