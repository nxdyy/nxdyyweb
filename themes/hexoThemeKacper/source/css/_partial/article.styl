.page-toc
  float: right
  .toc-number 
    color: rgba(51, 51, 51, 0.34)
  @media mq-tablet
    display: none
  @media mq-mobile
    display: none
  ul, ol, dl, li
    list-style: none
  ol.toc
    margin: 0
    position: relative
    margin: 0px 0 0 20px
    background: color-card-bg
    padding: 16px
    border-radius: border-radius-md
    max-width: 280px
    display: block
    overflow: hidden
    top: 0
    right: 0
    z-index: 999
    box-shadow: shadow-sm
    border: 1px solid color-border

.article
  margin: block-margin 0
  transition: all transition-normal

.article-inner
  overflow: hidden
  background: color-card-bg
  border-radius: border-radius-lg
  box-shadow: shadow-md
  transition: all transition-normal
  &:hover
    box-shadow: shadow-lg
    transform: translateY(-2px)

.article-meta
  clearfix()

.article-date
  float: left
  margin-top: 3px
  color: color-grey
  font-size: 0.9em
  &::before
    content: "\f073"
    font-family: FontAwesome
    margin-right: 6px
    color: color-link

.article-category
  float: left
  line-height: 1em
  color: color-link
  margin-left: 12px
  &:before
    content: "\f02d"
    font-family: FontAwesome
    margin-right: 4px

.article-category-link
  color: color-link
  margin: 0 8px 0
  text-decoration: none
  transition: all transition-fast
  &:hover
    text-decoration: underline

.article-header
  padding: article-padding article-padding 0

.page-buttons
  display: flex
  gap: 20px
  margin-top: 40px
  margin-bottom: 30px
  justify-content: center
  flex-wrap: wrap
  .page-btn
    position: relative
    display: inline-flex
    align-items: center
    padding: 14px 36px
    background: linear-gradient(135deg, color-primary 0%, color-secondary 100%)
    color: #fff
    text-decoration: none
    border-radius: border-radius-xl
    font-size: 0.95em
    font-weight: 600
    letter-spacing: 0.5px
    overflow: hidden
    transition: all transition-normal
    box-shadow: 0 4px 15px rgba(108, 92, 231, 0.3)
    cursor: pointer
    border: 2px solid transparent
    &::before
      content: ''
      position: absolute
      top: 50%
      left: 50%
      width: 0
      height: 0
      border-radius: 50%
      background: rgba(255, 255, 255, 0.2)
      transform: translate(-50%, -50%)
      transition: all transition-slow
    &:hover
      transform: translateY(-4px)
      box-shadow: 0 8px 25px rgba(108, 92, 231, 0.4)
      text-decoration: none
      &::before
        width: 400px
        height: 400px
    &:active
      transform: translateY(-2px)
      box-shadow: 0 4px 12px rgba(108, 92, 231, 0.3)

.article-title
  text-decoration: none
  font-size: 2.2em
  font-weight: 700
  color: color-default
  line-height: line-height-title
  transition: color transition-fast
  padding: 0 0 20px 0
  &:hover
    color: color-link

.article_api
  padding: 0 0px 0 270px
  background-color: color-card-bg
  @media mq-mobile
    padding: 0 0px
  .article-inner
    padding: 0 24px
    border-radius: border-radius-md
  .article-entry
    padding: 0
    a 
      img
        display: inline-block
        border-radius: border-radius-sm
  .page-toc
    position: fixed
    overflow: auto
    left: 0
    height: 100%
    background: color-card-bg
    box-shadow: shadow-sm
    @media mq-tablet
      display: block
    ol.toc
      margin: 0

.article-entry
  clearfix()
  color: color-default
  padding: 0 article-padding
  p, table
    line-height: line-height
    margin: (line-height * 0.6) 0
  h1, h2, h3, h4, h5, h6
    font-weight: 700
    margin: (line-height * 0.8) 0 (line-height * 0.4) 0
    color: color-default
  h1
    font-size: 2em
    padding-bottom: 10px
    border-bottom: 2px solid color-border
  h2
    font-size: 1.7em
    padding-bottom: 8px
    border-bottom: 1px solid color-border
  h3
    font-size: 1.4em
  h4
    font-size: 1.2em
  h5
    font-size: 1.1em
  h6
    font-size: 1em
    color: color-grey
  a
    color: color-link
    text-decoration: none
    position: relative
    padding-bottom: 2px
    transition: all transition-fast
    &::after
      content: ''
      position: absolute
      bottom: 0
      left: 0
      width: 0
      height: 2px
      background: color-link
      transition: width transition-normal
    &:hover
      text-decoration: none
      color: color-gradient-end
      &::after
        width: 100%
  img, video
    max-width: 100%
    height: auto
    display: block
    margin: 20px auto
    border-radius: border-radius-md
    box-shadow: shadow-sm
    transition: all transition-normal
    &:hover
      box-shadow: shadow-md
      transform: scale(1.01)
  iframe
    border: none
    border-radius: border-radius-md
  table
    width: 100%
    border-collapse: collapse
    border-spacing: 0
    margin: 20px 0
    border-radius: border-radius-sm
    overflow: hidden
    thead
      background: linear-gradient(135deg, color-primary, color-secondary)
      color: #fff
    th
      font-weight: 600
      padding: 14px 16px
      text-align: left
    td
      border-top: 1px solid color-border
      padding: 12px 16px
    tbody tr
      transition: background transition-fast
      &:hover
        background: color-card-hover
  blockquote
    background: linear-gradient(135deg, rgba(108, 92, 231, 0.05), rgba(162, 155, 254, 0.05))
    border-left: 4px solid color-primary
    padding: 16px 20px
    margin: 20px 0
    border-radius: 0 border-radius-sm border-radius-sm 0
    color: color-default
    font-family: font-serif
    font-size: 1em
    p
      margin: 0
    footer
      font-size: font-size
      margin: 10px 0 0 0
      font-family: font-sans
      cite
        &:before
          content: "—"
          padding: 0 0.5em
  .pullquote
    text-align: left
    width: 45%
    margin: 0
    &.left
      margin-left: 0.5em
      margin-right: 1em
    &.right
      margin-right: 0.5em
      margin-left: 1em
  .caption
    color: color-grey
    display: block
    font-size: 0.9em
    margin-top: 10px
    position: relative
    text-align: center
  .video-container
    position: relative
    padding-top: (9 / 16 * 100)%
    height: 0
    overflow: hidden
    border-radius: border-radius-md
    iframe, object, embed
      position: absolute
      top: 0
      left: 0
      width: 100%
      height: 100%
      margin-top: 0

.article_box
  padding: 30px 0 80px 0

.article_index
  float: left
  width: 50%
  min-height: 1px
  margin-top: 40px
  transition: all transition-normal
  &:hover
    transform: translateY(-4px)
  @media mq-tablet
    width: 100%
  @media mq-mobile
    width: 100%
  h4
    font-size: 18px
    margin: 12px 0
    color: color-primary
    padding: 0 0 0 20px
    font-weight: 700
    text-rendering: optimizelegibility
    position: relative
    &::before
      content: ''
      position: absolute
      left: 0
      top: 50%
      width: 4px
      height: 20px
      background: linear-gradient(180deg, color-primary, color-secondary)
      transform: translateY(-50%)
      border-radius: 2px
  p
    margin: 0 0 12px
    line-height: 24px
    color: color-grey
    padding: 0 30px 0 20px

.article-more-link a
  display: inline-flex
  align-items: center
  line-height: 1em
  padding: 10px 20px
  border-radius: border-radius-xl
  background: linear-gradient(135deg, color-primary, color-secondary)
  color: #fff
  text-shadow: none
  text-decoration: none
  transition: all transition-normal
  box-shadow: 0 2px 8px rgba(108, 92, 231, 0.3)
  font-weight: 500
  &:hover
    transform: translateY(-2px)
    box-shadow: 0 4px 12px rgba(108, 92, 231, 0.4)
    text-decoration: none

.article-footer
  clearfix()
  font-size: 0.9em
  line-height: line-height
  padding-top: line-height
  margin: 0 article-padding article-padding
  border-top: 1px solid color-border
  a
    color: color-grey
    text-decoration: none
    transition: color transition-fast
    &:hover
      color: color-link

.article-tag-list
  list-style: none
  display: inline-flex
  flex-wrap: wrap
  gap: 8px
  padding: 0

.article-tag-list-item
  float: none
  margin-right: 0

.article-tag-list-link  
  background: linear-gradient(135deg, rgba(108, 92, 231, 0.1), rgba(162, 155, 254, 0.1))
  border-radius: border-radius-xl
  padding: 4px 12px
  color: color-primary
  font-weight: 500
  font-size: 0.85em
  transition: all transition-fast
  display: inline-block
  &:hover
    background: linear-gradient(135deg, color-primary, color-secondary)
    color: #fff
    text-decoration: none
  &:before
    content: "#"
    margin-right: 2px

.article-comment-link
  float: right
  color: color-primary
  transition: all transition-fast
  &:before
    content: "\f075"
    font-family: font-icon
    padding-right: 8px
  &:hover
    color: color-gradient-end

.article-share-link
  cursor: pointer
  float: right
  margin-left: 20px
  color: color-primary
  transition: all transition-fast
  &:before
    content: "\f064"
    font-family: font-icon
    padding-right: 6px
  &:hover
    color: color-gradient-end

$icon-awesome
  display: inline-block
  font-style: normal
  &:before
    font-family: font-icon
    padding-right: 6px

.icon-github-alt
  @extend $icon-awesome
  &:before
    content: "\f113"
.icon-book
  @extend $icon-awesome
  color: color-primary
  &:before
    content: "\f02d"
.icon-bolt
  @extend $icon-awesome
  color: color-accent
  &:before
    content: "\f135"
    
.icon-lab
  @extend $icon-awesome
  color: color-secondary
  &:before
    content: "\f0f0"

#article-nav
  clearfix()
  position: relative
  @media mq-normal
    margin: block-margin 0
    &:before
      absolute-center(8px)
      content: ""
      border-radius: 50%
      background: linear-gradient(135deg, color-primary, color-secondary)
      box-shadow: 0 0 0 4px rgba(108, 92, 231, 0.1)

.article-nav-link-wrap
  text-decoration: none
  color: color-grey
  box-sizing: border-box
  margin-top: block-margin
  text-align: center
  display: block
  padding: 16px
  background: color-card-bg
  border-radius: border-radius-md
  box-shadow: shadow-sm
  transition: all transition-normal
  &:hover
    color: color-default
    box-shadow: shadow-md
    transform: translateY(-2px)
    text-decoration: none
  @media mq-normal
    width: 50%
    margin-top: 0

#article-nav-newer
  @media mq-normal
    float: left
    text-align: right
    padding-right: 20px

#article-nav-older
  @media mq-normal
    float: right
    text-align: left
    padding-left: 20px

.article-nav-caption
  text-transform: uppercase
  letter-spacing: 2px
  color: color-link
  line-height: 1em
  font-weight: 600
  #article-nav-newer &
    margin-right: -2px

.article-nav-title
  font-size: 0.9em
  line-height: line-height
  margin-top: 8px
  color: color-default

.article-share-box
  position: absolute
  display: none
  background: color-card-bg
  box-shadow: shadow-lg
  border-radius: border-radius-md
  margin-left: -145px
  overflow: hidden
  z-index: 1
  &.on
    display: block

.article-share-input
  width: 100%
  background: none
  box-sizing: border-box
  font: 14px font-sans
  padding: 0 15px
  color: color-default
  outline: none
  border: 1px solid color-border
  border-radius: border-radius-md border-radius-md 0 0
  height: 40px
  line-height: 40px

.article-share-links
  clearfix()
  background: color-background

$article-share-link
  width: 50px
  height: 40px
  display: block
  float: left
  position: relative
  color: color-grey
  transition: all transition-fast
  &:before
    font-size: 20px
    font-family: font-icon
    absolute-center(@font-size)
    text-align: center
  &:hover
    color: #fff

.article-share-twitter
  @extend $article-share-link
  &:before
    content: "\f099"
  &:hover
    background: color-twitter
    text-shadow: 0 1px darken(color-twitter, 20%)

.article-share-facebook
  @extend $article-share-link
  &:before
    content: "\f09a"
  &:hover
    background: color-facebook
    text-shadow: 0 1px darken(color-facebook, 20%)

.article-share-pinterest
  @extend $article-share-link
  &:before
    content: "\f0d2"
  &:hover
    background: color-pinterest
    text-shadow: 0 1px darken(color-pinterest, 20%)

.article-share-google
  @extend $article-share-link
  &:before
    content: "\f0d5"
  &:hover
    background: color-google
    text-shadow: 0 1px darken(color-google, 20%)

.article-gallery
  background: #000
  position: relative
  border-radius: border-radius-md
  overflow: hidden

.article-gallery-photos
  position: relative
  overflow: hidden

.article-gallery-img
  display: none
  max-width: 100%
  &:first-child
    display: block
  &.loaded
    position: absolute
    display: block
  img
    display: block
    max-width: 100%
    margin: 0 auto
    border-radius: 0
